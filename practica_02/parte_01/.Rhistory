geom_point(color = "red") +
theme_minimal()
p
lin.mod = lm(dist~speed,
data=cars)
summary(lin.mod)
gaussian.reg.1 <- glm(dist~speed,
data=cars,
family=gaussian(link="identity"))
summary(gaussian.reg.1)
gaussian.reg.2 <- glm(dist~speed,
data=cars,
family=gaussian(link="log"))
