library(xgboost)
library(Matrix)
set.seed(42)
n <- 50000; p <- 50
X <- matrix(rnorm(n*p), n, p)
y <- rbinom(n, 1, 0.5)
dtrain <- xgb.DMatrix(X, label = y)
params <- list(
objective = "binary:logistic",
eval_metric = "logloss",
tree_method = "gpu_hist"  # <- GPU
)
bst <- xgb.train(params, dtrain, nrounds = 200)
