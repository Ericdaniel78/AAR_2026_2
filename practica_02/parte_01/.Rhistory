list(E_bin=E_bin, Var_bin=Var_bin, E_poi=E_poi, Var_poi=Var_poi)
p_bin <- pbinom(18, size = n, prob = p)
p_poi <- ppois(18, lambda = lambda)
c(P_bin_le_18=p_bin, P_poi_le_18=p_poi, diff=p_bin-p_poi)
k <- 0:40
plot(k, dpois(k, lambda), type="h", lwd=3, col="gray40",
main = "PMF: Poisson(λ=np) vs Binomial(n,p)", xlab = "k", ylab = "P(N=k)")
points(k, dbinom(k, n, p), pch=19, col="steelblue")
legend("topright", c("Poisson","Binomial"), lwd=c(3,NA), pch=c(NA,19),
col=c("gray40","steelblue"), bty="n")
mu_hat <- 50; var_hat <- 100
pois_ok <- (abs(var_hat - mu_hat) < 1e-6)  # FALSE → sobre-dispersión
p_nb <- mu_hat / var_hat
r_nb <- mu_hat * p_nb / (1 - p_nb)
c(p_nb = p_nb, r_nb = r_nb, poisson_adecuado = pois_ok)
R <- 10000
sim_poi <- rpois(R, lambda = mu_hat)
sim_nb  <- rnbinom(R, size = r_nb, prob = p_nb)
data.frame(
modelo = c("Poisson(50)", sprintf("NB(r=%.1f,p=%.2f)", r_nb, p_nb)),
media  = c(mean(sim_poi), mean(sim_nb)),
var    = c(var(sim_poi),  var(sim_nb))
)
hist(sim_poi, breaks = 50, col = rgb(0,0,0,0.3), freq = FALSE,
main = "Poisson vs NB (sobre-dispersión)", xlab = "N")
hist(sim_nb, breaks = 50, col = rgb(0,0,1,0.3), freq = FALSE, add = TRUE)
legend("topright", c("Poisson","NegBin"), fill = c(rgb(0,0,0,0.3), rgb(0,0,1,0.3)), bty = "n")
xm <- 20000; alpha <- 2
E_X <- (alpha * xm)/(alpha - 1)
tail_prob <- (xm / 200000)^alpha
c(E_X = E_X, P_X_gt_200k = tail_prob)
R <- 200000
x <- rpareto(R, xm = xm, alpha = alpha)
c(media_emp = mean(x), prob_emp = mean(x > 200000))
hist(x, breaks = 200, main = "Pareto simulada (cola pesada)",
xlab = "Monto", xlim = c(0, 300000), col = "gray85", border = "white")
abline(v = 200000, col = "red", lwd = 2, lty = 2)
lambda <- 4
theta  <- 1/5000  # rate
E_S <- lambda * (1/theta)
Var_S <- lambda * (1/theta^2) + lambda * (1/theta)^2
c(E_S = E_S, Var_S = Var_S)
R <- 100000
N <- rpois(R, lambda = lambda)
S <- numeric(R)
idx <- N > 0
S[idx] <- sapply(N[idx], function(n) sum(rexp(n, rate = theta)))
prob_gt_50k <- mean(S > 50000)
qS <- quantile(S, c(0.95, 0.99))
c(P_S_gt_50k = prob_gt_50k, q95 = qS[1], q99 = qS[2])
hist(S, breaks = 100, main = "S ~ Poisson-Exponencial (simulación)",
xlab = "S", col = "lightsteelblue", border = "white")
abline(v = c(50000, qS), col = c("red","darkgreen","purple"), lwd = 2, lty = 2)
legend("topright", legend = c("50k","q95","q99"),
col = c("red","darkgreen","purple"), lty = 2, lwd = 2, bty = "n")
r_nb <- 10; p_nb <- 0.8
xm <- 25000; alpha <- 2.2
E_N <- r_nb * (1 - p_nb) / p_nb
E_X <- (alpha * xm) / (alpha - 1)
E_S <- E_N * E_X
c(E_N = E_N, E_X = E_X, E_S = E_S)
R <- 100000
N <- rnbinom(R, size = r_nb, prob = p_nb)
S <- numeric(R)
idx <- N > 0
S[idx] <- sapply(N[idx], function(n) sum(rpareto(n, xm = xm, alpha = alpha)))
prob_gt_200k <- mean(S > 200000)
qS <- quantile(S, c(0.95, 0.99))
c(P_S_gt_200k = prob_gt_200k, q95 = qS[1], q99 = qS[2])
hist(S, breaks = 120, main = "S ~ NB-Pareto (simulación)",
xlab = "S", col = "moccasin", border = "white", xlim = c(0, 800000))
abline(v = c(200000, qS), col = c("red","darkgreen","purple"), lwd = 2, lty = 2)
legend("topright", legend = c("200k","q95","q99"),
col = c("red","darkgreen","purple"), lty = 2, lwd = 2, bty = "n")
n <- 10000
pi0 <- 0.7
shape <- 2; scale <- 1200
u <- runif(n)
Y_mix <- ifelse(u < pi0, 0, rgamma(n, shape = shape, scale = scale))
c(mean = mean(Y_mix), var = var(Y_mix), pct_zero = mean(Y_mix == 0))
hist(Y_mix[Y_mix>0], breaks = 80, main = "Mezcla 0 + Gamma (parte positiva)",
xlab = "Siniestro positivo", col = "tan", border = "white")
library(tweedie)
set.seed(777)
Y_tw <- rtweedie(n = 10000, mu = 2000, phi = 1.5, power = 1.5)
c(mean_Tw = mean(Y_tw), var_Tw = var(Y_tw), pct_zero_Tw = mean(Y_tw == 0))
hist(Y_tw[Y_tw>0], breaks = 80, main = "Tweedie simulado (parte positiva)",
xlab = "Siniestro positivo", col = "lightgreen", border = "white")
set.seed(42)
celdas <- expand.grid(
zona=c("A","B"), uso=c("P","C"), edad=c("<=25","26-50",">50"),
KEEP.OUT.ATTRS=FALSE
)
expos <- sample(200:800, nrow(celdas), replace=TRUE)
freq_base <- 0.04; sev_base <- 30000
f_zona <- c(A=1.0, B=1.3)
f_uso  <- c(P=1.0, C=1.15)
f_edad_freq <- c(`<=25`=1.2, `26-50`=1.0, `>50`=0.9)
f_edad_sev  <- c(`<=25`=1.05, `26-50`=1.0, `>50`=1.1)
df <- celdas
df$expo <- expos
df$freq <- freq_base * f_zona[df$zona] * f_uso[df$uso] * f_edad_freq[df$edad]
df$sev  <- sev_base  * f_uso[df$uso]    * f_edad_sev[df$edad]
df$pp   <- df$freq * df$sev
df$pp_w <- df$pp * df$expo
df  # tabla por celda
pp_prom_ponderado <- sum(df$pp_w)/sum(df$expo)
pp_prom_ponderado
set.seed(42)
celdas <- expand.grid(
zona=c("A","B"), uso=c("P","C"), edad=c("<=25","26-50",">50"),
KEEP.OUT.ATTRS=FALSE
)
expos <- sample(200:800, nrow(celdas), replace=TRUE)
freq_base <- 0.04; sev_base <- 30000
f_zona <- c(A=1.0, B=1.3)
f_uso  <- c(P=1.0, C=1.15)
f_edad_freq <- c(`<=25`=1.2, `26-50`=1.0, `>50`=0.9)
f_edad_sev  <- c(`<=25`=1.05, `26-50`=1.0, `>50`=1.1)
df <- celdas
df$expo <- expos
df$freq <- freq_base * f_zona[df$zona] * f_uso[df$uso] * f_edad_freq[df$edad]
df$sev  <- sev_base  * f_uso[df$uso]    * f_edad_sev[df$edad]
df$pp   <- df$freq * df$sev
df$pp_w <- df$pp * df$expo
df  # tabla por celda
pp_prom_ponderado <- sum(df$pp_w)/sum(df$expo)
pp_prom_ponderado
